<%= turbo_frame_tag :new_product_category, target: :product_organization do %>
  <%= render component("ui/modal").new(title: t(".title")) do |modal| %>
    <%= form_for @product_category, url: solidus_admin.product_categories_path(@product) do |f| %>
      <div class="flex flex-col gap-6 pb-4">
        <%= render component("ui/forms/field").text_field(f, :name, class: "required") %>
      </div>
      <% modal.with_actions do %>
        <form method="dialog">
          <%= render component("ui/button").new(scheme: :secondary, text: t('.cancel')) %>
        </form>
        <%= render component("ui/button").new(type: :submit, text: t('.submit')) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
